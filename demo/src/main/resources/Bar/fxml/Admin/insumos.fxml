<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>

<AnchorPane prefHeight="1200.0" prefWidth="1900.0" stylesheets="@../../styles/EstiloGeneral.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Bar.view.InterfazAdmin.ControllerDatosInsumoAlmacen">
   <children>
      <BorderPane layoutX="67.0" layoutY="57.0" prefHeight="200.0" prefWidth="200.0" stylesheets="@../../styles/EstiloGeneral.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <ToolBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
              <items>
                <Button fx:id="btnNuevoProducto" mnemonicParsing="false" styleClass="btn-actualizar" stylesheets="@../../styles/estiloJefe.css" text="Nuevo Producto" />
                  <Button fx:id="btnEditar" mnemonicParsing="false" text="Editar" />
                  <Button fx:id="btnEliminar" mnemonicParsing="false" styleClass="button-danger" text="Eliminar" />
                  <TextField fx:id="textBuscar" styleClass="date-picker" />
              </items>
            </ToolBar>
         </top>
         <center>
            <TableView fx:id="tableAlmacen" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
              <columns>
                <TableColumn fx:id="colID" minWidth="75.0" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="colNombre" minWidth="250.0" prefWidth="300.0" text="Nombre" />
                  <TableColumn fx:id="colCantidad" prefWidth="300.0" text="Cantidad" />
              </columns>
            </TableView>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
